generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model jobs {
  id          BigInt   @id(map: "Jobs_pkey") @default(autoincrement())
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  title       String?
  company     String?
  location    String?
  description String?
}
