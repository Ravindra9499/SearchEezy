generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model jobs {
  id                 BigInt         @id(map: "Jobs_pkey") @default(autoincrement())
  created_at         DateTime       @default(now()) @db.Timestamptz(6)
  title              String?
  company            String?
  location           String?
  description        String?
  userEmail          String?
  jobType            String?
  screeningQuestions String?
  applications       applications[]
}

model applications {
  id          BigInt   @id @default(autoincrement())
  name        String?
  email       String?
  resumeLink  String?
  coverLetter String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  jobId       BigInt
  job         jobs     @relation(fields: [jobId], references: [id], onDelete: Cascade)
}
